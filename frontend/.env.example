# SpaceAI FC — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# FastAPI backend URL (default: localhost:8000)
VITE_API_URL=http://localhost:8000/api

# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenRouter — get from https://openrouter.ai/keys
# Optional: if not set, app uses backend template-based responses
VITE_OPENROUTER_API_KEY=your-openrouter-api-key
